# FoodOrdering — monorepo root

# --- Dependencies
**/node_modules/

# --- Next.js (frontend)
frontend/.next/
frontend/out/
frontend/build/
frontend/.vercel
frontend/*.tsbuildinfo

# --- Python (backend)
backend/__pycache__/
backend/**/__pycache__/
backend/*.py[cod]
backend/$py.class
backend/.venv/
backend/venv/
backend/.pytest_cache/
backend/.mypy_cache/
backend/.ruff_cache/
backend/dist/
backend/*.egg-info/
backend/.eggs/

# --- Secrets & local env (commit only *.example templates)
.env
.env.*
!.env.example
!**/.env.example
!**/env.example

# --- Logs & debug
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# --- OS & editors
.DS_Store
.idea/
.vscode/
*.swp
*.swo
Thumbs.db

# --- Test / coverage
coverage/
.nyc_output/
htmlcov/
.pytest_cache/
.tox/

# --- Misc
*.sqlite
*.sqlite3
*.db
.Python
