# Copy to backend/.env — never commit .env
AZURE_OPENAI_URL=https://YOUR_RESOURCE.openai.azure.com/
AZURE_OPENAI_KEY=
AZURE_OPENAI_API_VERSION=2025-01-01-preview
AZURE_OPENAI_MODEL=gpt-4o-mini
# Separate deployment for embeddings (Azure → Deployments). If unset or errors,
# upload still returns 200 but embeddingDim=0 and chat uses the full document text.
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small
CORS_ORIGINS=
HOST=0.0.0.0
PORT=8000
CHUNK_MAX_CHARS=1500
CHUNK_OVERLAP=200
EMBED_BATCH_SIZE=16
# How many chunk passages to send to the LLM after similarity search
RAG_TOP_K=5
# Return 200 with a stub reply without calling Azure chat (dev only). Set to 0 for production.
# CHAT_MOCK=0
